# Sanity CMS — fill in after creating a project at https://sanity.io/manage
# When these are unset, the site falls back to the hardcoded content in
# content/products.ts and the /studio route won't function.

NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Booking persistence — server-only Sanity write token (Editor scope) from
# sanity.io/manage → API → Tokens. Without it, the booking form returns a
# "not configured" error and customers are pointed to WhatsApp.
SANITY_API_WRITE_TOKEN=

# Emails (Resend — https://resend.com). RESEND_API_KEY enables sending;
# BOOKING_EMAIL_FROM must be on a domain you've verified in Resend (or use
# Resend's shared "onboarding@resend.dev" sender while testing).
# BOOKING_NOTIFICATION_EMAIL is where new-booking alerts go (defaults to the
# business email in content/business.ts). ENQUIRY_NOTIFICATION_EMAIL is where
# contact-form enquiries go; if unset it falls back to BOOKING_NOTIFICATION_EMAIL.
RESEND_API_KEY=
BOOKING_EMAIL_FROM="Nilantha Cushion Works <bookings@nilanthacushionworks.lk>"
BOOKING_NOTIFICATION_EMAIL=
ENQUIRY_NOTIFICATION_EMAIL=

# Public site URL, used for links in emails (later phases).
NEXT_PUBLIC_SITE_URL=https://nilanthacushionworks.lk

# Protects the reminder cron endpoint (/api/cron/reminders). Set any long random
# string; on Vercel it's sent automatically as a Bearer token on scheduled runs.
# When unset (local dev) the endpoint can be triggered without auth.
CRON_SECRET=

# Google Calendar push (optional). Create a service account + JSON key, enable
# the Google Calendar API, and share the target calendar with the service
# account email ("Make changes to events"). Paste the private key on one line
# with literal \n in place of newlines. When unset, bookings simply skip the
# calendar step.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID=
